# Avatar PRODUCTION configuration — used by docker-compose.prod.yml.
# Copy to .env, fill in the REQUIRED values, then:
#   docker compose -f docker-compose.prod.yml up -d --build
# See docs/deployment.md and SECURITY.md.

# --- REQUIRED ---------------------------------------------------------------

# Strong, unique API key. Generate: openssl rand -hex 32
# The app/worker REFUSE to boot if this is unset or a known default.
AVATAR_API_KEY=

# Postgres password (the database is the entire system of record — back it up).
POSTGRES_PASSWORD=

# Public hostname Caddy will obtain a TLS certificate for (DNS must point here).
AVATAR_DOMAIN=avatar.example.com

# HTTP basic-auth for /app and /metrics. Generate the bcrypt hash with:
#   docker run --rm caddy:2-alpine caddy hash-password -plaintext '<your-password>'
CADDY_BASICAUTH_USER=admin
CADDY_BASICAUTH_HASH=

# --- OPTIONAL (defaults shown) ----------------------------------------------

# POSTGRES_USER=avatar
# POSTGRES_DB=avatar

# Your agents/tools module(s), comma-separated. Leave empty if registering
# elsewhere. e.g. AVATAR_APP=yourpkg.agents
AVATAR_APP=

# Backpressure.
AVATAR_RATE_LIMIT_PER_SECOND=50
AVATAR_MAX_QUEUE_DEPTH=10000

# Connection pool per process — keep (api_replicas + workers) * pool under
# Postgres max_connections.
AVATAR_DB_POOL_SIZE=10
AVATAR_DB_MAX_OVERFLOW=20

# Tool isolation: use "subprocess" for anything less than fully trusted.
# There is no network/SSRF sandbox — do not run untrusted agent code. See SECURITY.md.
# AVATAR_TOOL_ISOLATION=subprocess
