# Avatar configuration — one infra dependency (Postgres), one auth secret.
# Copy to .env and adjust. This file is for LOCAL DEVELOPMENT.
# For production see .env.prod.example + docs/deployment.md.

# Local dev mode: allows the default API key and injects it into the dashboard
# for convenience. NEVER set this in production.
AVATAR_DEV_MODE=1

# Database. SQLite for local hacking; Postgres for real durability/crash tests.
# AVATAR_DATABASE_URL=sqlite+aiosqlite:///./avatar.db
AVATAR_DATABASE_URL=postgresql+asyncpg://avatar:avatar@localhost:5432/avatar

# The single static API key. `Authorization: Bearer <key>`.
# In production this MUST be a strong, unique value or the app refuses to boot.
AVATAR_API_KEY=dev-key

# The developer "app" module(s) the worker/API import to register agents+tools.
AVATAR_APP=avatar.demo

# Engine tuning (sane defaults shown).
AVATAR_LEASE_SECONDS=30
AVATAR_HEARTBEAT_SECONDS=10
AVATAR_POLL_INTERVAL_MS=500
AVATAR_MAX_STEPS=50
AVATAR_MAX_ATTEMPTS=5
AVATAR_TOOL_TIMEOUT_SECONDS=30

# Tool isolation: "inproc" (default) or "subprocess" (less-trusted tools).
# AVATAR_TOOL_ISOLATION=subprocess

# Backpressure / rate limiting (defaults shown).
AVATAR_RATE_LIMIT_PER_SECOND=50
AVATAR_RATE_LIMIT_BURST=100
AVATAR_MAX_QUEUE_DEPTH=10000

# DB connection pool (Postgres only).
AVATAR_DB_POOL_SIZE=10
AVATAR_DB_MAX_OVERFLOW=20
